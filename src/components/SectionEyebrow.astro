---
interface Props {
  label: string;
  number?: string;
}
const { label, number } = Astro.props;
---

<div class="flex items-center gap-3 text-xs uppercase tracking-[0.22em] text-brand-muted mb-6">
  {number && <span class="font-mono tabular-nums">{number}</span>}
  <span class="h-px w-8 bg-brand-line"></span>
  <span>{label}</span>
</div>
