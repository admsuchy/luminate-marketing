---
interface Props {
  title: string;
  description: string;
  icon: string;
  index?: number;
}
const { title, description, icon, index = 0 } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<article class="group relative p-8 md:p-10 border border-brand-line rounded-2xl bg-white/40 hover:bg-white hover:border-brand-primary/40 transition-all duration-300">
  <div class="flex items-start justify-between mb-6">
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center group-hover:bg-brand-primary group-hover:text-brand-ink transition-colors">
      <Fragment set:html={icon} />
    </div>
    <span class="text-xs font-mono text-brand-muted tabular-nums">{num}</span>
  </div>
  <h3 class="text-xl md:text-2xl mb-3">{title}</h3>
  <p class="text-sm md:text-base text-brand-muted leading-relaxed">{description}</p>
</article>
