---
interface Props {
  class?: string;
  variant?: 'dark' | 'light';
  size?: 'sm' | 'md' | 'lg';
}
const {
  class: className = '',
  variant = 'dark',
  size = 'md',
} = Astro.props;

const heights = {
  sm: 'h-6 md:h-7',
  md: 'h-7 md:h-9',
  lg: 'h-9 md:h-12',
};

// PNG source is white-on-transparent. `brightness(0)` renders it black for
// light surfaces; `light` variant uses it as-is (still white) for dark sections.
const filter = variant === 'dark' ? 'filter brightness-0' : '';
---

<a
  href="/"
  class={`inline-flex items-center group ${className}`}
  aria-label="Luminate Energy home"
>
  <img
    src="/logo.png"
    alt="Luminate Energy"
    width="3163"
    height="837"
    class={`${heights[size]} w-auto transition-opacity duration-200 group-hover:opacity-80 ${filter}`}
    loading="eager"
    decoding="async"
  />
</a>
