---
import Layout from '../layouts/Layout.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';

// Web3Forms is a free, no-signup-required form-to-email service.
// Replace this access key with your own from https://web3forms.com/ — until then,
// the form will display a friendly message instead of submitting.
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<Layout
  title="Contact — Luminate Energy"
  description="Get in touch with Luminate Energy for a free, no-pressure residential solar consultation in California, Texas, Arkansas, Florida, Missouri, or Georgia."
>
  <!-- HERO -->
  <section class="container-prose pt-20 md:pt-32 pb-12 md:pb-16">
    <SectionEyebrow label="Contact" number="01" />
    <h1 class="display-xl text-5xl md:text-7xl lg:text-8xl max-w-4xl mb-8">
      Let's <span class="accent-serif text-brand-primary">talk solar.</span>
    </h1>
    <p class="text-lg md:text-2xl text-brand-muted max-w-2xl leading-snug">
      Tell us a little about your home and we'll be in touch within one business day.
      No pressure, no obligation.
    </p>
  </section>

  <!-- FORM + INFO -->
  <section class="hairline-top">
    <div class="container-prose py-16 md:py-24 grid md:grid-cols-[1.4fr_1fr] gap-12 md:gap-20">

      <!-- FORM -->
      <div>
        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          class="space-y-6"
          novalidate
        >
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="New Luminate Energy lead from luminate.solar" />
          <input type="hidden" name="from_name" value="luminate.solar" />
          <input type="hidden" name="redirect" value="false" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs uppercase tracking-widest text-brand-muted mb-2 font-medium">Name</label>
              <input
                id="name"
                type="text"
                name="name"
                required
                autocomplete="name"
                class="w-full bg-transparent border-b border-brand-line focus:border-brand-ink outline-none py-3 text-base md:text-lg transition-colors"
              />
            </div>
            <div>
              <label for="phone" class="block text-xs uppercase tracking-widest text-brand-muted mb-2 font-medium">Phone</label>
              <input
                id="phone"
                type="tel"
                name="phone"
                autocomplete="tel"
                class="w-full bg-transparent border-b border-brand-line focus:border-brand-ink outline-none py-3 text-base md:text-lg transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="email" class="block text-xs uppercase tracking-widest text-brand-muted mb-2 font-medium">Email</label>
            <input
              id="email"
              type="email"
              name="email"
              required
              autocomplete="email"
              class="w-full bg-transparent border-b border-brand-line focus:border-brand-ink outline-none py-3 text-base md:text-lg transition-colors"
            />
          </div>

          <div>
            <label for="address" class="block text-xs uppercase tracking-widest text-brand-muted mb-2 font-medium">Home Address</label>
            <input
              id="address"
              type="text"
              name="address"
              autocomplete="street-address"
              placeholder="Street, city, ZIP"
              class="w-full bg-transparent border-b border-brand-line focus:border-brand-ink outline-none py-3 text-base md:text-lg transition-colors placeholder:text-brand-muted/60"
            />
          </div>

          <div>
            <label for="message" class="block text-xs uppercase tracking-widest text-brand-muted mb-2 font-medium">What can we help with?</label>
            <textarea
              id="message"
              name="message"
              rows="4"
              class="w-full bg-transparent border-b border-brand-line focus:border-brand-ink outline-none py-3 text-base md:text-lg transition-colors resize-none"
              placeholder="Average monthly bill, roof age, anything else we should know..."
            ></textarea>
          </div>

          <div class="pt-2 space-y-3">
            <p class="text-xs md:text-sm text-brand-muted leading-relaxed">
              SMS is used to communicate with customers regarding their solar project
              status and next steps. Messages include weekly account updates, utility
              approval, inspection scheduling, and responses to customer inquiries. By
              checking the box below, you agree to receive recurring SMS text messages
              from <strong>Luminate Energy</strong>. Message frequency varies (up to 2
              messages per week). Reply <strong>STOP</strong> to opt out,
              <strong>HELP</strong> for help. Message and data rates may apply. See our
              <a href="/privacy" class="underline">Privacy Policy</a> for full SMS terms.
            </p>
            <label class="flex items-start gap-3 cursor-pointer">
              <input
                type="checkbox"
                name="sms_opt_in"
                value="yes"
                class="mt-1 h-4 w-4 accent-brand-primary"
              />
              <span class="text-sm text-brand-ink">Opt in for SMS</span>
            </label>
          </div>

          <div class="pt-4 flex flex-col sm:flex-row sm:items-center gap-4">
            <button
              type="submit"
              class="inline-flex items-center justify-center gap-2 rounded-full bg-brand-ink text-brand-paper hover:bg-brand-primary hover:text-brand-ink transition-colors px-8 py-4 text-base font-medium disabled:opacity-50"
            >
              <span class="submit-label">Send message</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12"></line>
                <polyline points="12 5 19 12 12 19"></polyline>
              </svg>
            </button>
            <p class="text-xs text-brand-muted">By submitting, you agree to be contacted about your inquiry.</p>
          </div>

          <div
            id="form-status"
            class="hidden text-base"
            role="status"
            aria-live="polite"
          ></div>
        </form>
      </div>

      <!-- INFO -->
      <aside class="space-y-10 md:pt-2">
        <div>
          <h3 class="text-xs uppercase tracking-widest text-brand-muted mb-3 font-medium">Email</h3>
          <a href="mailto:support@luminate.solar" class="text-lg md:text-xl hover:text-brand-primary transition-colors">
            support@luminate.solar
          </a>
        </div>

        <div>
          <h3 class="text-xs uppercase tracking-widest text-brand-muted mb-3 font-medium">Instagram</h3>
          <a href="https://instagram.com/luminate.energy" target="_blank" rel="noopener noreferrer" class="text-lg md:text-xl hover:text-brand-primary transition-colors">
            @luminate.energy
          </a>
        </div>

        <div>
          <h3 class="text-xs uppercase tracking-widest text-brand-muted mb-3 font-medium">Service Area</h3>
          <p class="text-base md:text-lg text-brand-muted leading-relaxed">
            California &middot; Texas &middot; Arkansas <br />
            Florida &middot; Missouri &middot; Georgia
          </p>
        </div>

        <div>
          <h3 class="text-xs uppercase tracking-widest text-brand-muted mb-3 font-medium">Hours</h3>
          <p class="text-base md:text-lg text-brand-muted leading-relaxed">
            Mon–Sat &middot; 9am–7pm CT<br />
            We respond within 1 business day.
          </p>
        </div>

        <div class="pt-6 border-t border-brand-line">
          <p class="accent-serif text-2xl md:text-3xl leading-snug text-brand-ink">
            "On a mission to change lives through clean, renewable energy."
          </p>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status') as HTMLDivElement | null;
  const accessKeyInput = form?.querySelector<HTMLInputElement>('input[name="access_key"]');

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const label = submitBtn?.querySelector<HTMLSpanElement>('.submit-label');

      // If access key missing, show fallback mailto guidance instead of hitting the API.
      if (!accessKeyInput?.value) {
        status.className = 'block text-base text-brand-ink p-4 bg-brand-primary/10 border border-brand-primary/20 rounded-lg';
        status.innerHTML = 'Form not yet wired up. Please email <a href="mailto:support@luminate.solar" class="underline">support@luminate.solar</a> directly while we finish setup.';
        return;
      }

      if (submitBtn) submitBtn.disabled = true;
      if (label) label.textContent = 'Sending...';

      try {
        const formData = new FormData(form);
        const res = await fetch(form.action, {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();

        if (data.success) {
          status.className = 'block text-base text-brand-ink p-4 bg-brand-primary/10 border border-brand-primary/20 rounded-lg';
          status.textContent = 'Thanks — we got your message and will be in touch within one business day.';
          form.reset();
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch (err) {
        status.className = 'block text-base text-red-700 p-4 bg-red-50 border border-red-200 rounded-lg';
        status.innerHTML = 'Something went wrong. Please email <a href="mailto:support@luminate.solar" class="underline">support@luminate.solar</a> and we\'ll get back to you.';
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        if (label) label.textContent = 'Send message';
      }
    });
  }
</script>
