---
import Layout from '../layouts/Layout.astro';
import CTAButton from '../components/CTAButton.astro';
import SectionEyebrow from '../components/SectionEyebrow.astro';
import UsMap from '../components/UsMap.astro';
---

<Layout
  title="About — Luminate Energy"
  description="Luminate Energy is a multi-state residential solar installer serving California, Texas, Arkansas, Florida, Missouri, and Georgia — on a mission to change lives through clean, renewable energy."
>
  <!-- HERO -->
  <section class="container-prose pt-20 md:pt-32 pb-16 md:pb-24">
    <SectionEyebrow label="About" number="01" />
    <h1 class="display-xl text-5xl md:text-7xl lg:text-8xl max-w-4xl mb-8 md:mb-10">
      We're here to make solar <br />
      <span class="accent-serif text-brand-primary">feel like home.</span>
    </h1>
    <p class="text-lg md:text-2xl text-brand-muted max-w-2xl leading-snug mb-12 md:mb-16">
      Luminate Energy is a residential solar company serving California, Texas,
      Arkansas, Florida, Missouri, and Georgia — built on a simple idea: families
      deserve clean power, honest answers, and craftsmanship they can trust.
    </p>
    <div class="relative rounded-2xl overflow-hidden border border-brand-line shadow-sm aspect-[16/10] md:aspect-[21/9]">
      <img
        src="/images/about-customer-home.jpg"
        alt="A Texas home with a Luminate Energy solar install at golden hour"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  </section>

  <!-- FOOTPRINT MAP -->
  <section class="hairline-top">
    <div class="container-prose py-20 md:py-32">
      <div class="grid md:grid-cols-[1fr_1.6fr] gap-12 md:gap-20 items-start">
        <div class="md:sticky md:top-28 h-fit">
          <SectionEyebrow label="Footprint" number="02" />
          <h2 class="text-3xl md:text-5xl mb-6">
            Six states. <br />
            <span class="accent-serif text-brand-primary">Growing fast.</span>
          </h2>
          <p class="text-base md:text-lg text-brand-muted leading-relaxed max-w-md">
            We design, install, and support residential solar systems across
            California, Texas, Arkansas, Florida, Missouri, and Georgia — and
            we're not stopping there.
          </p>
        </div>
        <div>
          <UsMap />
        </div>
      </div>
    </div>
  </section>

  <!-- ORIGIN STORY -->
  <section class="hairline-top">
    <div class="container-prose py-20 md:py-28 grid md:grid-cols-[1fr_1.6fr] gap-12 md:gap-20">
      <div class="md:sticky md:top-28 h-fit">
        <SectionEyebrow label="Our story" number="03" />
        <h2 class="text-3xl md:text-5xl">
          A different kind of <br />
          <span class="accent-serif text-brand-primary">solar company.</span>
        </h2>
      </div>
      <div class="space-y-6 text-base md:text-lg leading-relaxed text-brand-muted max-w-prose">
        <p>
          Solar should never feel like a high-pressure sale. It's a decades-long
          investment in your home and your family — and it deserves to be treated
          that way.
        </p>
        <p>
          Luminate Energy was built around a different approach: lead with
          education, answer every question honestly, and only recommend a system
          if it genuinely makes sense for the homeowner.
        </p>
        <p>
          From the first conversation to the day your meter starts spinning
          backward, we treat your home like our own. That's the standard. That's
          the whole point.
        </p>
        <p class="text-brand-ink accent-serif text-2xl md:text-3xl leading-snug pt-4">
          "On a mission to change lives through clean, renewable energy."
        </p>
      </div>
    </div>
  </section>

  <!-- TEAM TEASER -->
  <section class="hairline-top container-prose py-20 md:py-28">
    <div class="grid md:grid-cols-[1.6fr_1fr] gap-12 md:gap-20 items-center">
      <div>
        <SectionEyebrow label="The team" number="04" />
        <h2 class="text-3xl md:text-5xl mb-6">
          Real people. <br />
          <span class="accent-serif text-brand-primary">In your corner.</span>
        </h2>
        <p class="text-base md:text-lg text-brand-muted leading-relaxed max-w-prose">
          From your first consultation through years after install, the same
          team is here to answer questions, troubleshoot, and make sure your
          system keeps performing. No call-center handoffs, no ghosting.
        </p>
      </div>
      <div class="flex items-center justify-center">
        <img
          src="/logo.png"
          alt="Luminate Energy"
          width="3163"
          height="837"
          class="w-full max-w-md h-auto filter brightness-0"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="hairline-top">
    <div class="container-prose py-24 md:py-32 text-center">
      <h2 class="text-4xl md:text-6xl mb-8 max-w-3xl mx-auto">
        Let's <span class="accent-serif text-brand-primary">talk solar.</span>
      </h2>
      <p class="text-lg md:text-xl text-brand-muted max-w-xl mx-auto mb-10">
        No pressure, no obligation. Just an honest conversation about your home.
      </p>
      <CTAButton href="/contact/" variant="primary" size="lg">Get in touch</CTAButton>
    </div>
  </section>
</Layout>
